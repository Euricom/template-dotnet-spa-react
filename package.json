{
  "name": "template-dotnet-spa-react",
  "type": "module",
  "private": true,
  "description": "AI Masterclass SPA Template",
  "devDependencies": {
    "rimraf": "^6.1.3",
    "vite-plus": "^0.1.14"
  },
  "workspaces": [
    "packages/web-react",
    "packages/web-tanstack-start",
    "packages/web-ng"
  ],
  "scripts": {
    "dev:ng": "bun run --filter 'web-ng' dev",
    "dev:react": "bun run --filter 'web-react' dev",
    "dev:tanstack": "bun run --filter 'web-tanstack-start' dev",
    "dev:api": "dotnet watch run --project packages/api",
    "check": "bun run --filter '*' check",
    "fallow": "bun run --filter '*' fallow",
    "test:api": "dotnet test packages/api.tests",
    "test:api:int": "dotnet test packages/api.tests.integration",
    "cleanup": "bun run --filter '*' cleanup"
  },
  "packageManager": "bun@1.3.6"
}