{
  "name": "template-dotnet-spa-react",
  "type": "module",
  "private": true,
  "description": "AI Masterclass SPA Template",
  "devDependencies": {
    "rimraf": "^6.1.3",
    "vite-plus": "^0.1.14"
  },
  "workspaces": [
    "packages/web"
  ],
  "scripts": {
    "dev": "bun run --filter 'web' dev",
    "lint": "bun run --filter 'web' lint",
    "lint:fix": "bun run --filter 'web' lint:fix",
    "fmt": "bun run --filter 'web' fmt",
    "fmt:check": "bun run --filter 'web' fmt:check",
    "check": "bun run --filter 'web' check",
    "dev:api": "dotnet watch run --project packages/api",
    "test:api": "dotnet test packages/api.tests",
    "test:api:int": "dotnet test packages/api.tests.integration",
    "clean": "rimraf packages/web/dist packages/api*/bin packages/api*/obj"
  },
  "packageManager": "bun@1.3.6"
}
